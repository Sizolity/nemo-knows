# Example DeepSeek API configuration.
# Copy this file to .env and fill in your own API key locally.
# Do not put real secrets in this tracked example file.

NEMO_MODEL_PROVIDER=deepseek
NEMO_DEEPSEEK_BASE_URL=https://api.deepseek.com
NEMO_DEEPSEEK_API_KEY=

NEMO_DEEPSEEK_MODEL=deepseek-v4-pro
NEMO_DEEPSEEK_MAX_TOKENS=384000
NEMO_DEEPSEEK_THINKING=enabled
NEMO_DEEPSEEK_REASONING_EFFORT=high
NEMO_DEEPSEEK_RESPONSE_FORMAT=text

# Optional DeepSeek-only request fields.
NEMO_DEEPSEEK_USER_ID=nemo-local
NEMO_DEEPSEEK_SYSTEM_PROMPT=
NEMO_DEEPSEEK_RETRY_MAX=2
NEMO_DEEPSEEK_RETRY_BASE_MS=1000

# Only used when NEMO_DEEPSEEK_THINKING=disabled.
# NEMO_DEEPSEEK_TEMPERATURE=0.2
# NEMO_DEEPSEEK_TOP_P=0.9

# Optional model-capability settings for model-aware chunk decisions.
# DeepSeek defaults to a 1M-token context and reserves the active max_tokens
# output budget plus scaffolding/reasoning headroom before estimating input.
# NEMO_MODEL_CONTEXT_TOKENS=1000000
# NEMO_CHARS_PER_TOKEN=3.5
# NEMO_CONTEXT_RESERVE_TOKENS=100000
# NEMO_CONTEXT_OUTPUT_RESERVE_TOKENS=384000
# NEMO_CONTEXT_SAFETY_MARGIN=0.60
# Quality cap for long sources that fit mechanically but degrade semantically.
# Set to 0 to disable this cap and use only the model-context budget.
# NEMO_QUALITY_CHUNK_THRESHOLD_CHARS=600000

# Optional chunked-bundle overrides. These win over model/quality defaults.
# Use them to force chunking for auditability or force single-shot for A/B runs.
# NEMO_CHUNKED_THRESHOLD_CHARS=1000000
# NEMO_MAX_CHUNK_CHARS=60000
