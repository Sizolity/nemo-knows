# Example DeepSeek API configuration.
# Copy this file to .env and fill in your own API key locally.
# Do not put real secrets in this tracked example file.

NEMO_MODEL_PROVIDER=deepseek
NEMO_DEEPSEEK_BASE_URL=https://api.deepseek.com
NEMO_DEEPSEEK_API_KEY=

NEMO_DEEPSEEK_MODEL=deepseek-v4-pro
NEMO_DEEPSEEK_MAX_TOKENS=384000
NEMO_DEEPSEEK_THINKING=enabled
NEMO_DEEPSEEK_REASONING_EFFORT=high
NEMO_DEEPSEEK_RESPONSE_FORMAT=text

# Optional DeepSeek-only request fields.
NEMO_DEEPSEEK_USER_ID=nemo-local
NEMO_DEEPSEEK_SYSTEM_PROMPT=

# Only used when NEMO_DEEPSEEK_THINKING=disabled.
# NEMO_DEEPSEEK_TEMPERATURE=0.2
# NEMO_DEEPSEEK_TOP_P=0.9

# Optional chunked-bundle overrides. The defaults are provider-aware:
# llama -> 90000 / 18000, deepseek -> 300000 / 60000. Override only when a
# specific source exceeds the provider default or when you want to force the
# chunked path for auditability.
# NEMO_CHUNKED_THRESHOLD_CHARS=300000
# NEMO_MAX_CHUNK_CHARS=60000
