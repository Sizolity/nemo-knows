# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Direnv / local env
.envrc
.env
.env.local

# Python / Node / common scratch (in case CLI tooling is added later)
__pycache__/
*.pyc
node_modules/
.cache/

# Local-only working files (ignored by convention)
scratch/
tmp/
experiments/
.bin/
.cursor

# Local tar snapshots and regenerated eval outputs
backups/
evals/runs/

# Full llama.cpp traces next to cleaned bundle/candidate drafts (regenerate locally)
drafts/**/*.raw.txt
drafts/**/*.fallback.raw.txt

# Local web console runtime log
web.log

# Server-side deployment state
.deploy-state/
.releases/

# Runtime-regenerated wiki pages. Keep only the required wiki skeleton in Git:
# wiki/index.md, wiki/log.md, and directory placeholders.
wiki/sources/*
wiki/entities/*
wiki/concepts/*
wiki/topics/*
wiki/assets/*
!wiki/sources/.gitkeep
!wiki/entities/.gitkeep
!wiki/concepts/.gitkeep
!wiki/topics/.gitkeep
!wiki/assets/.gitkeep
